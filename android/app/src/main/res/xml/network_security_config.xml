<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for user-configured LAN or tailnet gateway addresses. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
